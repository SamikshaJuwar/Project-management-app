generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPERADMIN
  MANAGER
  EMPLOYEE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  password     String
  role         Role     @default(EMPLOYEE)
  githubToken  String?
  githubLogin  String?
  githubToken2 String?
  githubLogin2 String?
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  managerId  String?
  manager    User?        @relation("ManagerEmployees", fields: [managerId], references: [id])
  employees  User[]       @relation("ManagerEmployees")

  issues      Issue[]
  attendances Attendance[]
  timesheets  Timesheet[]
  subprojects Subproject[] @relation("SubprojectUsers")
  tasks       Task[]
}

model Project {
  id                  String      @id @default(cuid())
  name                String
  description         String?
  repoOwner           String?
  repoName            String?
  githubProjectId     String?
  githubProjectNumber Int?
  status              String      @default("active")
  startDate           DateTime?
  endDate             DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  milestones          Milestone[]
  issues              Issue[]
  subprojects         Subproject[]
  subprojectColumns   SubprojectColumn[]
  meetings            Meeting[]
}

model SubprojectColumn {
  id          String       @id @default(cuid())
  name        String
  description String?
  color       String       @default("bg-slate-50 border-slate-200")
  accent      String       @default("bg-slate-400")
  order       Int          @default(0)
  isVisible   Boolean      @default(true)
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subprojects Subproject[] @relation("ColumnSubprojects")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Subproject {
  id            String    @id @default(cuid())
  name          String
  description   String?
  startDate     DateTime?
  endDate       DateTime?
  status        String    @default("Planned") // Planned, In Progress, Completed
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columnId      String?
  column        SubprojectColumn? @relation("ColumnSubprojects", fields: [columnId], references: [id])
  tasks         Task[]
  milestones    Milestone[]
  assignedUsers User[]    @relation("SubprojectUsers")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Task {
  id            String      @id @default(cuid())
  title         String
  description   String?
  status        String      @default("To Do") // To Do, In Progress, Done
  subprojectId  String
  subproject    Subproject  @relation(fields: [subprojectId], references: [id], onDelete: Cascade)
  assigneeId    String?
  assignee      User?       @relation(fields: [assigneeId], references: [id])
  labels        String[]
  dueDate       DateTime?
  commentsCount Int         @default(0)
  likesCount    Int         @default(0)
  repostsCount  Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  milestone     Milestone?
}

model Milestone {
  id                    String    @id @default(cuid())
  title                 String
  description           String?
  dueDate               DateTime?
  githubMilestoneId     BigInt?
  githubMilestoneNumber Int?
  state                 String    @default("open")
  projectId             String
  project               Project   @relation(fields: [projectId], references: [id])
  
  subprojectId          String?
  subproject            Subproject? @relation(fields: [subprojectId], references: [id])
  
  taskId                String?   @unique
  task                  Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  issues                Issue[]
}

model Issue {
  id                String     @id @default(cuid())
  title             String
  body              String?
  githubIssueId     BigInt?
  githubIssueNumber Int?
  state             String     @default("open")
  labels            String[]
  assigneeId        String?
  assignee          User?      @relation(fields: [assigneeId], references: [id])
  projectId         String?
  project           Project?   @relation(fields: [projectId], references: [id])
  milestoneId       String?
  milestone         Milestone? @relation(fields: [milestoneId], references: [id])
  commentsCount     Int        @default(0)
  likesCount        Int        @default(0)
  repostsCount      Int        @default(0)
  startDate         DateTime?
  endDate           DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model Attendance {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime         @default(now()) @db.Date
  clockIn   DateTime
  clockOut  DateTime?
  status    AttendanceStatus @default(PRESENT)
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model Timesheet {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart   DateTime        @db.Date
  weekEnd     DateTime        @db.Date
  totalHours  Float           @default(0)
  status      TimesheetStatus @default(DRAFT)
  tasks       String?
  submittedAt DateTime?
  approvedAt  DateTime?
  approvedBy  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([userId, weekStart])
  @@index([userId])
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Meeting {
  id                 String        @id @default(cuid())
  agenda             String
  meetingType        String        // "project" | "other"
  projectId          String?
  project            Project?      @relation(fields: [projectId], references: [id])
  points             String?       // Discussion points
  attendeeIds        String[]      // Internal: User IDs
  externalAttendees  String[]      // External: email addresses
  meetingLink        String?       // Manual link (Google Meet, Zoom, etc.)
  dateTime           DateTime
  sendEmail          Boolean       @default(false)
  calendarSync       Boolean       @default(false)
  status             MeetingStatus @default(SCHEDULED)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  mom                MOM?
}

model MOM {
  id              String   @id @default(cuid())
  meetingId       String   @unique
  meeting         Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  attendeesNames  String   // Free-text list of names who attended
  pointsDiscussed String
  description     String?
  conclusion      String
  goalsSet        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}